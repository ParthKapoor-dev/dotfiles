{
  "formatter": "language_server",
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null
    },
    "enabled_in_text_threads": false
  },
  "project_panel": {
    "dock": "right"
  },
  "features": {
    "edit_prediction_provider": "zed"
  },
  "agent": {
    "default_model": {
      "provider": "ollama",
      "model": "deepseek-r1:8b"
    }
  },
  "icon_theme": "Catppuccin Mocha",
  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Espresso (Blur) [Heavy]",
    "dark": "CodeSandbox"
  },
  "buffer_font_family": "SF Mono",
  "buffer_font_weight": 300,
  "terminal": {
    "font_family": "JetBrains Mono"
  },
  "ui_font_family": "SF Mono",
  "relative_line_numbers": "enabled",
  "soft_wrap": "editor_width",
  "format_on_save": "on",
  "languages": {
    "Python": {
      "language_servers": [
        "ty",
        "!basedpyright"
      ]
    }
  }
}
